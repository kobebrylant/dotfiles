# ===================================================================
# KITTY TERMINAL CONFIGURATION - TWILIGHT THEME
# ===================================================================

# ===================================================================
# FONTS
# ===================================================================

font_family      JetBrains Mono
bold_font        JetBrains Mono Bold
italic_font      JetBrains Mono Italic
bold_italic_font JetBrains Mono Bold Italic

# Font size in pts
font_size 16.0

# Adjust line height (1.0 is normal)
adjust_line_height  0
adjust_column_width 0

# Disable ligatures on cursor hover (useful for code editing)
disable_ligatures cursor

# ===================================================================
# CURSOR
# ===================================================================

cursor_shape block
cursor_blink_interval 0.5
cursor_stop_blinking_after 15.0

# ===================================================================
# SCROLLBACK
# ===================================================================

scrollback_lines 10000
scrollback_pager less --chop-long-lines --RAW-CONTROL-CHARS +INPUT_LINE_NUMBER
wheel_scroll_multiplier 5.0
touch_scroll_multiplier 1.0

# ===================================================================
# MOUSE
# ===================================================================

mouse_hide_wait 3.0
url_style curly
open_url_with default
copy_on_select yes
strip_trailing_spaces smart

# ===================================================================
# TERMINAL BELL
# ===================================================================

enable_audio_bell no
visual_bell_duration 0.0
window_alert_on_bell yes
bell_on_tab yes

# ===================================================================
# WINDOW LAYOUT
# ===================================================================

remember_window_size  yes
initial_window_width  1200
initial_window_height 700

window_padding_width 4
window_border_width 1pt
draw_minimal_borders yes
inactive_text_alpha 0.8
hide_window_decorations no

# Tab bar style
tab_bar_edge bottom
tab_bar_style powerline
tab_powerline_style slanted
tab_title_template "{index}: {title}"

# ===================================================================
# TWILIGHT COLOR SCHEME
# Based on the classic TextMate Twilight theme
# Dark, warm colors with excellent readability
# ===================================================================

# Basic colors
# foreground #f8f8f8
# background #141414
# selection_foreground #141414
# selection_background #878787

# Cursor colors
# cursor #ffffff
# cursor_text_color #141414

# URL color
# url_color #cda869

# Tab bar colors
# active_tab_foreground   #f8f8f8
# active_tab_background   #1e1e1e
active_tab_font_style   bold
# inactive_tab_foreground #808080
# inactive_tab_background #2a2a2a
inactive_tab_font_style normal

# Black
# color0 #141414
# color8 #5f5a60

# Red
# color1 #cf6a4c
# color9 #cf6a4c

# Green
# color2  #8f9d6a
# color10 #8f9d6a

# Yellow
# color3  #f9ee98
# color11 #f9ee98

# Blue
# color4  #7587a6
# color12 #7587a6

# Magenta
# color5  #9b859d
# color13 #9b859d

# Cyan
# color6  #afc4db
# color14 #afc4db

# White
# color7  #ffffff
# color15 #ffffff

# Additional Twilight-specific colors for better syntax highlighting
# These are used by some terminal applications

# Orange (used for constants, tags)
# color16 #cda869

# Brown (used for comments)
# color17 #5f5a60

# ===================================================================
# KEYBOARD SHORTCUTS
# ===================================================================

# Clipboard
map ctrl+shift+c copy_to_clipboard
map ctrl+shift+v paste_from_clipboard
map ctrl+shift+s paste_from_selection

# Scrolling
map ctrl+shift+up   scroll_line_up
map ctrl+shift+down scroll_line_down
map ctrl+shift+page_up   scroll_page_up
map ctrl+shift+page_down scroll_page_down
map ctrl+shift+home scroll_home
map ctrl+shift+end  scroll_end

# Window management
map ctrl+shift+enter new_window
map ctrl+shift+w     close_window
map ctrl+shift+n     new_os_window
map ctrl+shift+]     next_window
map ctrl+shift+[     previous_window
map ctrl+shift+f     move_window_forward
map ctrl+shift+b     move_window_backward

# Tab management
map ctrl+shift+t     new_tab
map ctrl+shift+q     close_tab
map ctrl+shift+right next_tab
map ctrl+shift+left  previous_tab
map ctrl+shift+.     move_tab_forward
map ctrl+shift+,     move_tab_backward
map ctrl+shift+alt+t set_tab_title

# Font sizes
map ctrl+shift+equal     change_font_size all +2.0
map ctrl+shift+minus     change_font_size all -2.0
map ctrl+shift+backspace change_font_size all 0

# Layout management
map ctrl+shift+l next_layout

# Miscellaneous
map ctrl+shift+f11 toggle_fullscreen
map ctrl+shift+u   kitten unicode_input
map ctrl+shift+f2  edit_config_file
map ctrl+shift+escape kitty_shell window
map ctrl+shift+f5  load_config_file

# ===================================================================
# PERFORMANCE
# ===================================================================

repaint_delay 10
input_delay 3
sync_to_monitor yes

# ===================================================================
# ADVANCED
# ===================================================================

shell .
confirm_os_window_close 0
clipboard_control write-clipboard write-primary read-clipboard read-primary
shell_integration enabled

# ===================================================================
# OS SPECIFIC
# ===================================================================

linux_display_server auto
# macos_titlebar_color background
macos_option_as_alt yes

# Update check interval (in hours, 0 to disable)
update_check_interval 24

# ===================================================================
# TWILIGHT THEME NOTES
# ===================================================================
# This Twilight theme is inspired by the classic TextMate Twilight theme
# 
# Key colors:
# - Background: Deep charcoal (#141414) for reduced eye strain
# - Foreground: Off-white (#f8f8f8) for excellent contrast
# - Accent colors: Warm earth tones (browns, oranges, muted greens)
# 
# Perfect for:
# - Long coding sessions
# - Low-light environments
# - Developers who prefer warm, muted colors
# 
# Reload config: Ctrl+Shift+F5 or restart Kitty


# BEGIN_KITTY_THEME
# Pro
include current-theme.conf
# END_KITTY_THEME